{
  "name": "avatar-ao-baker",
  "version": "0.1.2",
  "private": true,
  "description": "Desktop AO baking tool for VRChat avatar workflows.",
  "license": "MIT",
  "author": "Just Alternative",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev:app": "vp run build:scripts && node dist-scripts/scripts/dev.js",
    "dev:renderer": "vp dev",
    "dev:electron:ts": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "build:app": "vp build && vp run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "dist:win": "vp run build:app && electron-builder --win nsis",
    "pack:win": "vp run build:app && electron-builder --dir --win nsis",
    "preview:renderer": "vp preview",
    "start": "electron dist-electron/electron/main.js",
    "test:ao": "vp test run src/lib/rayAoCore.test.ts",
    "typecheck": "vp run typecheck:tsgo",
    "typecheck:ts6": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "typecheck:tsgo": "tsgo -p tsconfig.json --noEmit && tsgo -p tsconfig.tsgo.electron.json --noEmit && tsgo -p tsconfig.tsgo.scripts.json --noEmit",
    "typecheck:strict": "tsgo -p tsconfig.json --noEmit --noUnusedLocals --noUnusedParameters",
    "typecheck:compare": "vp run typecheck:ts6 && vp run typecheck:tsgo"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.184.0",
    "three-mesh-bvh": "0.9.9"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.2",
    "electron-builder": "26.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plus": "0.1.20",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2",
  "build": {
    "appId": "com.sevensideorg.avataraobaker",
    "productName": "Avatar AO Baker",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/electron/main.js"
    },
    "win": {
      "icon": "svg/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Avatar-AO-Baker-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
